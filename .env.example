# Example environment variables for ReviewBot
# note: TEAMS must be valid JSON (single line or escaped newlines).
# common mistake: leaving trailing comma or unquoted IDs causes parse errors.

DISCORD_TOKEN=your_token_here
GUILD_ID=your_guild_id
CHANNEL_ID=your_channel_id
START_DATE=2025-01-02
TEAMS=[
  ["123456789012345678", "123456789012345679"],
  ["223456789012345678", "223456789012345679"]
]
